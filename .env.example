# StudyCafe Analytics System — Environment Variables Template
# Copy file này thành .env và điền giá trị thực

# Khi dùng Docker Compose: giữ nguyên giá trị mặc định
# Khi chạy local: sửa DATABASE_URL trỏ đến PostgreSQL local

DATABASE_URL=postgresql+asyncpg://studycafe:studycafe123@localhost:5432/studycafe
VITE_API_BASE_URL=http://localhost:8000
GOOGLE_PLACES_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

