# Example cho env.prod tren VPS 
# Run on vps:
# docker compose --env-file env.prod -f docker-compose.prod.yml up -d --build

POSTGRES_USER=studycafe
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=studycafe

# Domain HTTPS public. Vi du: https://studycafe.example.com
VITE_API_BASE_URL=https://studycafe.example.com
CORS_ORIGINS=https://studycafe.example.com

# Chi bind vao localhost de reverse proxy tren VPS truy cap noi bo.
BACKEND_PORT=8088
FRONTEND_PORT=5173

# Optional.
GOOGLE_PLACES_API_KEY=

REPORT_EXPORT_TOKEN=change-meeee
